# ─── Supabase ────────────────────────────────────────────────────────────────
# Encontrás estos valores en: Supabase Dashboard → Project Settings → API

# URL del proyecto (pública, va en el bundle)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Clave anon/public (pública, va en el bundle)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave service_role (SECRETA — nunca expongas esto)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── URL de la app ───────────────────────────────────────────────────────────
# URL pública donde corre la app (para webhooks de Mercadopago, emails, etc.)
# En producción: https://tudominio.com — sin barra al final
NEXT_PUBLIC_APP_URL=https://tudominio.com

# ─── Mercadopago ─────────────────────────────────────────────────────────────
# Encontrás el token en: https://www.mercadopago.com.ar/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxx-xxxx

# Secreto para verificar webhooks de Mercadopago (lo configurás en el panel de MP)
MERCADOPAGO_WEBHOOK_SECRET=tu_secreto_de_webhook

# ─── Brevo (email) ───────────────────────────────────────────────────────────
# Encontrás la API key en: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Cron jobs ───────────────────────────────────────────────────────────────
# Secreto para proteger los endpoints de cron (generá uno aleatorio)
# Ejemplo: openssl rand -hex 32
CRON_SECRET=un_secreto_largo_y_aleatorio
